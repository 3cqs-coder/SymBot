<script>
(function() {

	// Sections that start collapsed. Key is the exact bold text of the section header.
	const COLLAPSED_BY_DEFAULT = new Set([
		'3CQS Signals',
		'Telegram Settings',
		'Artificial Intelligence (AI)',
		'Database Backups',
		'SFTP Credentials For Backups'
	]);

	const STORAGE_KEY = 'symbot_config_sections';

	function loadState() {
		try {
			return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
		} catch(e) {
			return {};
		}
	}

	function saveState(state) {
		try {
			localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
		} catch(e) {}
	}

	function initCollapsibleSections() {

		const state = loadState();

		// Find every bold tag that is a direct section header — i.e. the first
		// element child of a padding-top div, not inside a table or label.
		const candidates = document.querySelectorAll('#formConfig > div > b');

		candidates.forEach(function(header) {

			const title = header.textContent.trim();

			if (!COLLAPSED_BY_DEFAULT.has(title)) {
				return;
			}

			const sectionDiv = header.parentElement;

			// Collect all siblings after the header <b> tag — these are the
			// table rows and other elements to hide/show.
			const siblings = [];
			let node = header.nextSibling;

			while (node) {
				siblings.push(node);
				node = node.nextSibling;
			}

			// Wrap siblings in a collapsible container
			const body = document.createElement('div');
			body.className = 'config-section-body';
			siblings.forEach(function(n) { body.appendChild(n); });
			sectionDiv.appendChild(body);

			// Determine initial open/closed state
			const savedOpen = state[title];
			const isOpen = savedOpen === undefined
				? false   // collapsed by default
				: savedOpen;

			body.style.display = isOpen ? '' : 'none';

			// Build the clickable header row
			const toggle = document.createElement('span');
			toggle.className = 'config-section-toggle';
			toggle.setAttribute('aria-expanded', String(isOpen));
			toggle.style.cssText = [
				'display: inline-flex',
				'align-items: center',
				'gap: 6px',
				'cursor: pointer',
				'user-select: none',
				'width: 100%',
				'padding: 2px 0 4px 0'
			].join(';');

			const arrow = document.createElement('span');
			arrow.className = 'config-section-arrow';
			arrow.textContent = isOpen ? '▾' : '▸';
			arrow.style.cssText = [
				'font-size: 0.85rem',
				'opacity: 0.6',
				'transition: transform 120ms ease',
				'flex-shrink: 0'
			].join(';');

			// Move the <b> tag into the toggle wrapper
			toggle.appendChild(arrow);
			toggle.appendChild(header);

			sectionDiv.insertBefore(toggle, sectionDiv.firstChild);

			toggle.addEventListener('click', function() {

				const open = body.style.display === 'none';

				body.style.display = open ? '' : 'none';
				arrow.textContent = open ? '▾' : '▸';
				toggle.setAttribute('aria-expanded', String(open));

				const s = loadState();
				s[title] = open;
				saveState(s);
			});
		});
	}

	// Run after the DOM is ready and after any existing $(document).ready
	// handlers have finished, so toggles (e.g. toggleTelegram) are already set.
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', function() {
			setTimeout(initCollapsibleSections, 0);
		});
	} else {
		setTimeout(initCollapsibleSections, 0);
	}

})();
</script>


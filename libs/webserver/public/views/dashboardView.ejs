<%- include('./partialsHeaderView'); %>

<script src="./js/vendor/chart.js/chart.js"></script>

<script>
    <% const { active_deals, total_in_deals, available_balance, total_profit, total_pl } = kpi; %>
    const { profit_by_bot_map, profit_by_day_map, active_pl_map, adjusted_pl_map, bot_deal_duration_map, bot_funds_in_use_map, max_funds_deals_map, equity_curve_map = {}, win_rate_map = {}, pair_profit_map = {}, pair_profit_pos_map = {}, pair_profit_neg_map = {}, so_utilisation_map = {} } = <%- JSON.stringify(charts) %>;
    const balances = <%- JSON.stringify(available_balance) %>;
    const currencies = <%- '[' + currencies.map(currency => `'${currency}'`).join(',') + ']'; %>;
    const botIdNameMap = <%- JSON.stringify(botIdNameMap) %>;

    const isDarkMode = document.body.getAttribute('data-theme') === 'dark';
    const chartGridColor = isDarkMode ? '#555555' : undefined;
    const chartTickColor = isDarkMode ? '#aaaaaa' : undefined;
    const chartLabelColor = isDarkMode ? '#d8d8d8' : undefined;

    // In dark mode use higher opacity so bars are vivid against dark background
    const bgColors = [
        isDarkMode ? 'rgba(255, 99, 132, 0.85)' : 'rgba(255, 99, 132, 0.2)',
        isDarkMode ? 'rgba(54, 162, 235, 0.85)' : 'rgba(54, 162, 235, 0.2)',
        isDarkMode ? 'rgba(255, 206, 86, 0.85)' : 'rgba(255, 206, 86, 0.2)',
        isDarkMode ? 'rgba(75, 192, 192, 0.85)' : 'rgba(75, 192, 192, 0.2)',
        isDarkMode ? 'rgba(153, 102, 255, 0.85)' : 'rgba(153, 102, 255, 0.2)',
        isDarkMode ? 'rgba(255, 159, 64, 0.85)' : 'rgba(255, 159, 64, 0.2)'
    ];

    const borderColors = [
        'rgba(255, 99, 132, 1)',
        'rgba(54, 162, 235, 1)',
        'rgba(255, 206, 86, 1)',
        'rgba(75, 192, 192, 1)',
        'rgba(153, 102, 255, 1)',
        'rgba(255, 159, 64, 1)'
    ];

    $(document).ready(function () {

        // --- Populate account balance ---
        function populateBalance(currency) {
            let balance = Number(balances[currency]);
            if (isNaN(balance)) balance = 0;
            $('#balance').html('$' + balance.toLocaleString());
        }

        const period_map = { 'week': 7, '2-weeks': 14, 'month': 30 };

        $.each(currencies, function(index, currency) {
            $('#currencies').append($('<option></option>').val(currency).html(currency));
        });

        populateBalance(currencies[0]);

        $('#currencies').change(function() {
            populateBalance($(this).val());
        });

        $('#period-select').change(function() {
            const tzData = getTimeZone();
            const timeZoneOffset = tzData['offset'];
            const period = $(this).val();
            window.location.href = `./dashboard?duration=${encodeURIComponent(period_map[period])}&timeZoneOffset=${encodeURIComponent(timeZoneOffset)}`;
        });

        const period = new URLSearchParams(window.location.search).get('duration');
        if (period) {
            const keys = Object.keys(period_map);
            let isCustom = true;
            for (let i = 0; i < keys.length; i++) {
                if (period_map[keys[i]] == period) {
                    $(`#period-select option[value=${keys[i]}]`).prop('selected', true);
                    isCustom = false;
                    break;
                }
            }
            if (isCustom) {
                $('#custom-date-range').css('display', 'block');
                $('#period-select option[value=custom]').prop('selected', true);
            }
        } else {
            $(`#period-select option[value=week]`).prop('selected', true);
        }

        <% if (isLoading) { %>
            alertBox('Deals are being loaded. Please wait a few minutes and refresh the page.');
        <% } %>

        // --- Line chart helper (equity curve) ---
        function createLineChart(ctx, label, data) {
            const keys = Object.keys(data);
            const values = keys.map(k => data[k] || 0);

            return new Chart(ctx, {
                type: 'line',
                data: {
                    labels: keys,
                    datasets: [{
                        label: label,
                        data: values,
                        borderColor: 'rgba(75, 192, 192, 1)',
                        backgroundColor: isDarkMode ? 'rgba(75, 192, 192, 0.4)' : 'rgba(75, 192, 192, 0.1)',
                        borderWidth: 2,
                        pointRadius: 3,
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return label + ': $' + context.raw.toLocaleString();
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: chartTickColor, callback: function(value) {
                                const str = this.getLabelForValue(value);
                                return window.matchMedia('only screen and (max-width: 768px)').matches
                                    ? str.substring(0, 6) : str.substring(0, 12);
                            }},
                            grid: { color: chartGridColor }
                        },
                        y: {
                            ticks: { color: chartTickColor, callback: function(value) {
                                return '$' + value.toLocaleString();
                            }},
                            grid: { color: chartGridColor }
                        }
                    }
                }
            });
        }

        // --- Chart creation helper ---
        function createChart(ctx, label, data, showMaxOnTop=false, maxData={}) {
            const moneyCharts = ['Bot Profit','Active P/L','Adjusted P/L','Profit Per Day','Funds in Use'];
            const isMoney = moneyCharts.includes(label);

            const keys = Object.keys(data);
            const labels = keys; // already using botName or date strings
            const values = keys.map(k => data[k] || 0);

            return new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: values,
                        backgroundColor: bgColors,
                        borderColor: borderColors,
                        borderWidth: 1
                    }]
                },
                options: {
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw.toLocaleString();
                                    return isMoney ? `${label}: $${value}` : `${label}: ${value}`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: chartTickColor, callback: function(value) {
                                const str = this.getLabelForValue(value);
                                return window.matchMedia("only screen and (max-width: 768px)").matches
                                    ? str.substring(0, 10) + ".."
                                    : str.substring(0, 20) + "..";
                            }},
                            grid: { color: chartGridColor }
                        },
                        y: {
                            ticks: { color: chartTickColor, callback: function(value) {
                                return isMoney ? '$' + value.toLocaleString() : value;
                            }},
                            grid: { color: chartGridColor }
                        }
                    }
                },
                plugins: [{
                    id: 'maxValueLabels',
                    afterDatasetsDraw: chart => {
                        if (!showMaxOnTop) return;
                        const ctx = chart.ctx;
                        chart.data.datasets.forEach((dataset, i) => {
                            chart.getDatasetMeta(i).data.forEach((bar, index) => {
                                const key = chart.data.labels[index];
                                const maxValue = maxData[key] || 0;
                                if (maxValue <= 0) return;

                                ctx.save();
                                ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--text-color') || '#999';
                                ctx.font = 'bold 12px Arial';
                                ctx.textAlign = 'center';
                                ctx.textBaseline = 'bottom';
                                ctx.fillText('$' + maxValue.toLocaleString(), bar.x, bar.y - 5);
                                ctx.restore();
                            });
                        });
                    }
                }]
            });
        }

        // --- Render all charts ---
        createChart(document.getElementById('botProfitChart').getContext('2d'), 'Bot Profit', profit_by_bot_map);
        createChart(document.getElementById('activePLChart').getContext('2d'), 'Active P/L', active_pl_map);
        createChart(document.getElementById('adjustedPLChart').getContext('2d'), 'Adjusted P/L', adjusted_pl_map);
        createChart(document.getElementById('profitPerDayChart').getContext('2d'), 'Profit Per Day', profit_by_day_map);
        createChart(document.getElementById('botDealDurationChart').getContext('2d'), 'Deal Duration (Minutes)', bot_deal_duration_map);
        createChart(
            document.getElementById('fundsInUseChart').getContext('2d'),
            'Funds in Use',
            bot_funds_in_use_map,
            true,
            max_funds_deals_map
        );

        // New charts
        if (Object.keys(equity_curve_map).length > 0) {
            createLineChart(document.getElementById('equityCurveChart').getContext('2d'), 'Cumulative Profit', equity_curve_map);
        } else {
            document.getElementById('equityCurveChart').parentElement.style.display = 'none';
        }

        createChart(document.getElementById('winRateChart').getContext('2d'), 'Win Rate (%)', win_rate_map);
        if (Object.keys(pair_profit_pos_map).length > 0) {
            createChart(document.getElementById('pairProfitPosChart').getContext('2d'), 'Pair Profit', pair_profit_pos_map);
        } else {
            document.getElementById('pairProfitPosChart').parentElement.style.display = 'none';
        }

        if (Object.keys(pair_profit_neg_map).length > 0) {
            createChart(document.getElementById('pairProfitNegChart').getContext('2d'), 'Pair Losses', pair_profit_neg_map);
        } else {
            document.getElementById('pairProfitNegChart').parentElement.style.display = 'none';
        }
        createChart(document.getElementById('soUtilisationChart').getContext('2d'), 'Avg Safety Orders Used', so_utilisation_map);

        // Hide the Max Deal Exposure chart
        document.getElementById('maxDealsFundsChart').parentElement.style.display = 'none';
    });
</script>

<main style="margin-top: 10px">
    <div id="contentBox" style="display: flex; flex-wrap: wrap;">
        <div style="flex: 1;">
            <div style="display: flex; flex-direction: column; justify-content: center; gap: 5px;">
                <select class="form-field" id="period-select" style="width: 100px;">
                    <option value="week">Week</option>
                    <option value="2-weeks">2 Weeks</option>
                    <option value="month" selected>Month</option>
                    <option value="custom" id="custom-date-range" style="display: none;">Custom</option>
                </select>
                <span><b>Period:</b> <%- period %></span>
            </div>
        </div>
        <div style="flex: 1; display: flex; align-items: flex-start; justify-content: flex-end;">
            <div id="rightBox" style="display: flex; align-items: center;">
                <b>Balance:</b>
                <select class="form-field" id="currencies" style="width: 100px; margin-left: 5px;"></select>
            </div>
        </div>
        <div id="belowContentBox" style="flex-basis: 100%; display: flex; justify-content: center; margin-top: 20px;">
            <div id="innerContent" style="flex: 1;">
                <div class="kpi-container">
                    <div class="performance-kpi">
                        <span style="font-size: 11px">Active Deals</span>
                        <span style="font-size: 20px;"><%- active_deals %></span>
                    </div>
                    <div class="performance-kpi">
                        <span style="font-size: 11px">Total In Deals</span>
                        <span style="font-size: 20px;">$<%- total_in_deals.toLocaleString() %></span>
                    </div>
                    <div class="performance-kpi">
                        <span style="font-size: 11px">Available Funds</span>
                        <span id="balance" style="font-size: 20px;"></span>
                    </div>
                    <div class="performance-kpi">
                        <span style="font-size: 11px">Profit</span>
                        <span style="font-size: 20px;">$<%- total_profit.toLocaleString() %></span>
                    </div>
                    <div class="performance-kpi">
                        <span style="font-size: 11px">Active P/L</span>
                        <span style="font-size: 20px;">$<%- total_pl.toLocaleString() %></span>
                    </div>
                </div>

                <div class="dashboard-container">
                    <div class="chart-container">
                        <canvas id="botProfitChart"></canvas>
                    </div>
                    <div class="chart-container">
                        <canvas id="activePLChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container">
                    <div class="chart-container" style="margin-top:40px">
                        <canvas id="adjustedPLChart"></canvas>
                    </div>
                    <div class="chart-container" style="margin-top:40px">
                        <canvas id="profitPerDayChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container" style="margin-top:40px; display:flex; flex-wrap:wrap; gap:20px;">
                    <div class="chart-container" style="flex:1 1 300px; min-width:300px;">
                        <canvas id="botDealDurationChart"></canvas>
                    </div>
                    <div class="chart-container" style="flex:1 1 300px; min-width:300px; display:flex; flex-direction:column; align-items:center;">
                        <p style="font-size:12px; text-align:center; margin-bottom:5px;">
                            Max deal exposure ever per bot shown
                        </p>
                        <canvas id="fundsInUseChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container">
                    <div class="chart-container" style="margin-top:40px; width: 100%;">
                        <canvas id="maxDealsFundsChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container" style="margin-top:40px;">
                    <div class="chart-container" style="width: 100%;">
                        <canvas id="equityCurveChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container" style="margin-top:40px; display:flex; flex-wrap:wrap; gap:20px;">
                    <div class="chart-container" style="flex:1 1 300px; min-width:300px;">
                        <canvas id="winRateChart"></canvas>
                    </div>
                    <div class="chart-container" style="flex:1 1 300px; min-width:300px;">
                        <canvas id="soUtilisationChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container" style="margin-top:40px;">
                    <div class="chart-container" style="width: 100%;">
                        <canvas id="pairProfitPosChart"></canvas>
                    </div>
                </div>

                <div class="dashboard-container" style="margin-top:40px;">
                    <div class="chart-container" style="width: 100%;">
                        <canvas id="pairProfitNegChart"></canvas>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

<%- include('./partialsFooterView'); %>

<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content" />
	<title><%- appData.name %> AI Chat</title>

	<%
		// Render base href server-side so the HTML parser sees it before resolving
		// any relative asset paths — JS-injected base tags fire too late.
		const basePath = (query && query.bp) ? decodeURIComponent(query.bp) : '/';
	%>
	<base href="<%- basePath %>">

	<link rel="stylesheet" href="css/style.css" />
	<link href="https://fonts.googleapis.com/css?family=Heebo:400,600,300" rel="stylesheet" type="text/css">
</head>

<body class="popout-body">

<div id="popoutHeader">
	<span id="popoutTitle">AI Chat</span>
	<div id="popoutHeaderBtns">
		<div id="popoutMode" title="Toggle theme"></div>
	</div>
</div>

<div id="aiChatSpinner" class="spinner-dynamic-container" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); display: none; z-index: 999;"><div class="spinner-dynamic"></div></div>

<div id="chatConversationBar">
	<select id="conversationSelect" class="form-field" title="Saved conversations" style="flex:1; min-width:0;"><option value="">New conversation</option></select>
	<button id="chatSaveBtn" class="btn btn-default" title="Save">Save</button>
	<button id="chatDeleteBtn" class="btn btn-default" title="Delete" style="display:none;">Delete</button>
</div>
<div class="aiChatContainer" id="popoutChatContainer">
	<div id="aiChatBox"></div>
</div>
<div id="chatInputContainer">
	<textarea id="chatInput" placeholder="Type your message here..." autocomplete="off" rows="1" style="resize:none;overflow:hidden;"></textarea>
	<button id="chatSendButton">Send</button>
</div>


<script src="js/vendor/jquery/jquery.min.js"></script>
<script src="js/vendor/marked/marked.min.js"></script>

<script>

	(function() {

		const params    = new URLSearchParams(window.location.search);
		const room      = params.get('room')  || '';
		const basePath  = params.get('bp')    || '/';
		const wsPath    = params.get('wsp')   || 'ws';
		const chatTitle = params.get('title') || 'AI Chat';
		const initConvId = params.get('conv_id') || '';
		window.AIChatConv_room         = room;
		window.AIChatConv_basePath     = basePath;
		window.AIChatConv_activeId     = initConvId || null;
		window.AIChatConv_sessionStart = 0;
		window.AIChatConv_firstMessage = (chatTitle && chatTitle !== 'AI Chat') ? chatTitle : null;
		window.AIChatConv_type         = (chatTitle && chatTitle !== 'AI Chat') ? 'analysis' : 'chat';
		window.AIChatConv_dealId       = params.get('deal_id') || '';

		// Pending file attachments
		let pendingAttachments = [];

		$('#popoutTitle').text(chatTitle);
		document.title = chatTitle;

		// ── Theme ────────────────────────────────────────────────────────────

		function applyMode(mode) {

			if (mode === 'dark') {

				document.body.setAttribute('data-theme', 'dark');
				$('#popoutMode').html('<span class="icon icon-moon" style="width:15px;height:15px;"></span>');
			}
			else {

				document.body.removeAttribute('data-theme');
				$('#popoutMode').html('<span class="icon icon-sun" style="width:15px;height:15px;"></span>');
			}
		}

		function getMode() {

			try {

				const dt = JSON.parse(localStorage.getItem('dataTracker'));
				return dt && dt.mode ? dt.mode : 'light';
			}
			catch(e) {

				return 'light';
			}
		}

		function toggleMode() {

			const current = getMode();
			const next = current === 'dark' ? 'light' : 'dark';

			try {

				const dt = JSON.parse(localStorage.getItem('dataTracker')) || {};
				dt.mode = next;
				localStorage.setItem('dataTracker', JSON.stringify(dt));
			}
			catch(e) {}

			applyMode(next);
		}

		// Sync theme when main app toggles it
		window.addEventListener('storage', function(e) {

			if (e.key === 'dataTracker') {

				applyMode(getMode());
			}
		});

		// ── Chat state ───────────────────────────────────────────────────────

		let $currentMessageElement = null;
		let messageBuffer = '';
		let canSendMessage = false;
		let socket;

		const $chatBox    = $('#aiChatBox');
		const $spinner    = $('#aiChatSpinner');
		const $input      = $('#chatInput');
		const $sendBtn    = $('#chatSendButton');

		function toggleInputState(disable) {

			$input.prop('disabled', disable);
			$sendBtn.prop('disabled', disable);
		}

		function scrollToBottom() {

			$chatBox.scrollTop($chatBox.prop('scrollHeight'));
		}

		function displayMessage(content) {

			if (content === 'END_OF_CHAT') {

				if ($currentMessageElement) {

					messageBuffer = '';
					$currentMessageElement = null;
				}

				canSendMessage = true;
				toggleInputState(false);
				$input[0].focus();

				if (typeof window.AIChatConv_autoSave === 'function') window.AIChatConv_autoSave();
			}
			else {

				if (!$currentMessageElement) {

					$currentMessageElement = $('<div>', { class: 'message bot-message' });
					$chatBox.append($currentMessageElement);
				}

				messageBuffer += content;
				$currentMessageElement.html(marked.parse(messageBuffer, { breaks: true }));
			}

			scrollToBottom();
		}

		function renderHistory(messages) {

			// Skip the first user message if it's long — it's a prompt template, not chat
			const firstUserIdx = messages.findIndex(function(m) { return m.role === 'user'; });

			messages.forEach(function(msg, idx) {

				if (msg.role === 'user') {

					// Hide first user message only if it looks like a prompt (> 200 chars)
					if (idx === firstUserIdx && msg.content.length > 200) return;

					const $userMsg = $('<div>', { class: 'message user-message', text: msg.content });
					if (msg.attachments && msg.attachments.length > 0) {
						msg.attachments.forEach(function(att) {
							$userMsg.append($('<span class="attach-badge">').text('📄 ' + att.name));
						});
					}
					$chatBox.append($userMsg);
				}
				else if (msg.role === 'assistant') {

					const $msg = $('<div>', { class: 'message bot-message' });
					$msg.html(marked.parse(msg.content, { breaks: true }));
					$chatBox.append($msg);
				}
			});

			scrollToBottom();
		}
		window.AIChatConv_renderHistory = renderHistory;

		function postChatPrompt(userMessage, attachments) {

			$spinner.show();
			toggleInputState(true);

			const payload = {
				message: {
					room: room,
					content: userMessage,
					attachments: attachments || []
				}
			};

			$.ajax({
				type: 'POST',
				url: basePath + 'api/ai/chat/prompt',
				contentType: 'application/json',
				data: JSON.stringify(payload),
				dataType: 'json',
				error: function(data) {

					$spinner.hide();
					toggleInputState(false);
					alert('Error sending message: ' + JSON.stringify(data));
				}
			});
		}

		function sendMessage() {

			const userMessage = $input.val().trim();

			if (!canSendMessage || !userMessage) return;

			canSendMessage = false;

			// Capture before clearing
			const attachmentsToSend = pendingAttachments.slice();

			const $userMsg = $('<div>', { class: 'message user-message', text: userMessage });
			if (attachmentsToSend.length > 0) {
				attachmentsToSend.forEach(function(att) {
					$userMsg.append($('<span class="attach-badge">').text('📄 ' + att.name));
				});
				pendingAttachments = [];
				renderAttachmentPills();
			}
			$chatBox.append($userMsg);
			$input.val('');

			if (!window.AIChatConv_firstMessage) window.AIChatConv_firstMessage = userMessage;

			postChatPrompt(userMessage, attachmentsToSend);
			scrollToBottom();
		}

		// ── Socket.IO ────────────────────────────────────────────────────────

		function connectSocket() {

			// Socket.IO client is served by the SymBot server itself
			$.getScript(basePath + wsPath + '/socket.io.min.js', function() {

				socket = io('/', {
					path: basePath + wsPath,
					transports: ['websocket', 'polling'],
					reconnection: true,
					reconnectionDelay: 10000
				});

				socket.on('connect', function() {

					socket.emit('joinRooms', { rooms: [room] });
				});

				socket.on('data', function(data) {

					if (data.type === 'message' && data.message) {

						if (messageBuffer === '') {

							$spinner.hide();
						}

						displayMessage(data.message);
					}
				});

				socket.on('connect_error', function() {});
				socket.on('disconnect', function() {});
			});
		}

		// ── Load history then connect ─────────────────────────────────────

		$(document).ready(function() {

			// Apply theme immediately
			applyMode(getMode());

			if (!room) {

				$spinner.hide();
				$chatBox.html('<div style="padding:20px;color:var(--table-content-color);">No chat room specified.</div>');
				return;
			}

			toggleInputState(true);

			if (initConvId && typeof window.AIChatConv_loadIntoRoom === 'function') {

				window.AIChatConv_loadIntoRoom(initConvId, function() {
					connectSocket();
					canSendMessage = true;
					toggleInputState(false);
				}, function() {
					connectSocket();
					canSendMessage = true;
					toggleInputState(false);
				});

			} else {

			// Fetch conversation history from server
			$.ajax({
				type: 'GET',
				url: basePath + 'api/ai/chat/history',
				data: { room: room },
				dataType: 'json',
				success: function(data) {

					$spinner.hide();

					if (data.success && data.messages && data.messages.length > 0) {

						renderHistory(data.messages);
					}
					else {

						$chatBox.append($('<div>', {
							class: 'message bot-message',
							text: 'Conversation history could not be loaded. The session may have expired.'
						}));
					}

					// Connect to socket after history is rendered
					connectSocket();

					canSendMessage = true;
					toggleInputState(false);
				},
				error: function(xhr, status, err) {

					$spinner.hide();
					$chatBox.append($('<div>', {
						class: 'message bot-message',
						text: 'Could not connect to chat session.'
					}));
					canSendMessage = true;
					toggleInputState(false);
				}
			});
			} // end else

			// Event handlers
			$('#popoutMode').on('click', toggleMode);


			// Paperclip button
			$('#chatAttachBtn').on('click', function() {
				$('#chatAttachFile').val('').trigger('click');
			});

			$('#chatAttachFile').on('change', async function() {

				const file = this.files[0];
				if (!file) return;

				const $uploading = $('<div class="chat-attachment-pill chat-attachment-uploading">')
					.append($('<span>').text('⏳ ' + file.name));
				$('#chatAttachments').append($uploading);
				$('#chatAttachBtn').prop('disabled', true);

				const formData = new FormData();
				formData.append('file', file);

				try {

					const resp = await fetch(basePath + 'api/ai/chat/upload', { method: 'POST', body: formData });
					const text = await resp.text();

					$uploading.remove();
					$('#chatAttachBtn').prop('disabled', false);

					let data;
					try { data = JSON.parse(text); } catch(pe) {
						alert('Upload failed: server returned unexpected response. Check logs.');
						return;
					}

					if (!data.success) { alert(data.error || 'Upload failed'); return; }

					pendingAttachments.push(data);
					renderAttachmentPills();

				} catch (e) {
					$uploading.remove();
					$('#chatAttachBtn').prop('disabled', false);
					alert('Upload error: ' + e.message);
				}
			});

			$sendBtn.on('click', sendMessage);

			$input.on('keydown', function(e) {

				if (e.which === 13 && !e.shiftKey && canSendMessage) {

					e.preventDefault();
					sendMessage();
				}
			});

			// Firefox mobile: re-focus input on tap to ensure keyboard input registers
			$input[0].addEventListener('touchend', function(e) {

				e.stopPropagation();
				setTimeout(function() { $input[0].focus(); }, 50);
			}, { passive: true });

			// Prevent container scroll from stealing touch events from input
			document.getElementById('chatInputContainer').addEventListener('touchstart', function(e) {

				e.stopPropagation();
			}, { passive: true });

			// Resize layout when mobile keyboard opens/closes
			if (window.visualViewport) {

				window.visualViewport.addEventListener('resize', function() {

					document.body.style.height = window.visualViewport.height + 'px';
					$('#chatInput')[0].scrollIntoView({ block: 'nearest' });
				});
			}

			// Leave room on close
			window.addEventListener('beforeunload', function() {

				if (socket) {

					socket.emit('leaveRoom', room);
				}
			});
		});

	})();

</script>

<script src="js/ai-chat-conversations.js?v=<%- appData.version %>"></script>

</body>
</html>
